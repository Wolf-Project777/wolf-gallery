    <string name="albums_test_header">Albums repository self-test</string>
    <string name="albums_test_subtitle">Creates a throwaway album with a Cyrillic name + emoji, lists it, renames it, sets a fake cover with a normalized crop rect, lists once more to verify the round-trip, then deletes the album. The default Imported album is NOT touched.</string>
