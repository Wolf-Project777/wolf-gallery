    <string name="native_header">Native (NDK) self-test</string>
    <string name="native_subtitle">Calls libencnative.so::secureZero on a 64-byte buffer pre-filled with 0xAA and verifies every byte is 0x00 on return.</string>
    <string name="btn_run_native_test">Run secureZero self-test</string>
    <string name="toast_native_pass">secureZero PASSED — all 64 bytes wiped</string>
    <string name="toast_native_fail">secureZero FAILED — see log</string>

    <string name="aesgcm_header">AES-256-GCM via StrongBox self-test</string>
    <string name="aesgcm_subtitle">Generates a hardware-backed AES-256 key under a TEST alias (PRODUCTION key is never touched), prefers StrongBox (Knox Vault on A14 5G). Verifies: hardware tier, two round-trips (small UTF-8 + 1 KiB random), ciphertext ≠ plaintext, IV uniqueness, ciphertext-tamper rejection, IV-tamper rejection. Test alias is deleted afterwards.</string>
    <string name="btn_run_aesgcm_test">Run AES-GCM/StrongBox self-test</string>
    <string name="aesgcm_running">Running on hardware…</string>
    <string name="toast_aesgcm_pass">AES-GCM/StrongBox PASSED — see log for hardware tier</string>
    <string name="toast_aesgcm_fail">AES-GCM/StrongBox FAILED — see log</string>

    <string name="securebytes_header">SecureBytes self-test (Tier 2)</string>
    <string name="securebytes_subtitle">Wraps 32 bytes in XOR-masked RAM with a per-read rotating mask. Verifies: caller buffer wiped, masked storage ≠ plaintext, round-trip read returns original, mask actually rotates, close() wipes everything, read-after-close throws, close is idempotent.</string>
    <string name="btn_run_securebytes_test">Run SecureBytes self-test</string>
    <string name="toast_securebytes_pass">SecureBytes PASSED — all 7 properties verified</string>
    <string name="toast_securebytes_fail">SecureBytes FAILED — see log</string>

    <string name="argon2_header">Argon2id self-test (memory-hard KDF)</string>
    <string name="argon2_subtitle">Derives a 32-byte key from \"password\"+\"somesalt12345678\" twice with the same params (must match), then once with a different salt (must differ). Uses 4 MiB / 2 iters / 1 thread for fast dev validation; production params are 64 MiB / 3 / 4.</string>
    <string name="btn_run_argon2_test">Run Argon2id self-test</string>
    <string name="argon2_running">Computing…</string>
    <string name="toast_argon2_pass">Argon2id PASSED — determinism + salt-sensitivity verified</string>
    <string name="toast_argon2_fail">Argon2id FAILED — see log</string>

    <string name="blob_header">Encrypted file blob self-test (per-file crypto)</string>
    <string name="blob_subtitle">Streams 2 MiB of random plaintext through CipherOutputStream, verifies the on-disk layout (magic + version + IV header, +36 bytes overhead), confirms ciphertext bytes ≠ plaintext bytes at the same offset, round-trips the file via decrypt and matches SHA-256, and checks that tampered ciphertext / bad magic / wrong version are all rejected. Uses a TEST Keystore alias; production master key is not touched.</string>
    <string name="btn_run_blob_test">Run blob round-trip self-test</string>
    <string name="blob_running">Encrypting + decrypting 2 MiB…</string>
    <string name="toast_blob_pass">Blob round-trip PASSED — all 6 properties verified</string>
    <string name="toast_blob_fail">Blob round-trip FAILED — see log</string>

