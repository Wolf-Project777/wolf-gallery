    <string name="toast_albums_pass">Albums self-test PASSED</string>
    <string name="toast_albums_fail">Albums self-test FAILED — see log</string>

    <string name="trash_test_header">Trash repository self-test</string>
    <string name="trash_test_subtitle">Creates a throwaway album + a synthetic vault entry, moves it to trash, lists trash + verifies meta round-trip + verifies original-album field, restores the entry back, moves to trash again, then permanently purges it and runs purgeOlderThan with a tiny retention to verify the auto-purge path. The default Imported album is NOT touched.</string>
